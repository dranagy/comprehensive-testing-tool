{
  "name": "@ctt/cli",
  "version": "0.1.0",
  "description": "Unified local testing platform combining functional, performance, and DAST security testing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ctt": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "serve": "node --import tsx src/api/server.ts",
    "serve:dist": "node dist/api/server.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "testing",
    "functional",
    "performance",
    "security",
    "dast",
    "playwright"
  ],
  "license": "MIT",
  "dependencies": {
    "artillery": "^2.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ink": "^5.0.0",
    "mammoth": "^1.8.0",
    "marked": "^15.0.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.52.0",
    "react": "^18.3.0",
    "uuid": "^11.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
